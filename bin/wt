#!/usr/bin/env bash
set -euo pipefail

show_usage() {
  echo "Usage: $(basename "$0") <command> [branch-name]"
  echo ""
  echo "Commands:"
  echo "  add <branch-name>    Create a new worktree from master"
  echo "  rm|remove [branch-name]  Remove an existing worktree (omit to remove current wt-price-* dir)"
  echo ""
  echo "Examples:"
  echo "  $(basename "$0") add rm-feature-flag"
  echo "  $(basename "$0") rm rm-feature-flag"
  echo "  $(basename "$0") rm    # remove current worktree when inside wt-price-*"
  echo ""
  echo "To cd automatically (add/rm), add this to your .zshrc:"
  echo '  wt() { $HOME/bin/wt "$@"; [ -f ~/.wt_cd_to ] && cd "$(cat ~/.wt_cd_to)" && rm ~/.wt_cd_to; }'
  exit 1
}

if [ $# -lt 1 ]; then
  show_usage
fi

COMMAND="$1"

resolve_rm_targets() {
  if [ $# -ge 2 ]; then
    BRANCH_NAME="$2"
    SAFE_NAME="${BRANCH_NAME//\//-}"
    WORKTREE_DIR="../wt-price-${SAFE_NAME}"
  else
    CWD="$(pwd)"
    BASENAME="$(basename "$CWD")"
    if [[ "$BASENAME" != wt-price-* ]]; then
      echo "Error: Not in a wt-price-* directory. Specify branch name or cd into the worktree first." >&2
      exit 1
    fi
    WORKTREE_DIR="$CWD"
    BRANCH_NAME="$(git branch --show-current)"
    if [ -z "$BRANCH_NAME" ]; then
      echo "Error: Not in a git worktree or detached HEAD." >&2
      exit 1
    fi
  fi
}

case "$COMMAND" in
  add)
    if [ $# -lt 2 ]; then
      echo "Error: 'add' requires a branch name." >&2
      show_usage
    fi
    BRANCH_NAME="$2"
    SAFE_NAME="${BRANCH_NAME//\//-}"
    WORKTREE_DIR="../wt-price-${SAFE_NAME}"
    if [ -d "$WORKTREE_DIR" ]; then
      echo "Error: Worktree directory '$WORKTREE_DIR' already exists."
      exit 1
    fi

    echo "Creating worktree at '$WORKTREE_DIR' with new branch '$BRANCH_NAME' from master..." >&2
    git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR" master

    echo "Done! Worktree created at: $WORKTREE_DIR (branch: $BRANCH_NAME)" >&2
    WORKTREE_ABS="$(cd "$WORKTREE_DIR" && pwd)"
    echo "$WORKTREE_ABS" > ~/.wt_cd_to
    ;;

  rm|remove)
    resolve_rm_targets "$@"
    REMOVING_CURRENT=$([ $# -lt 2 ] && echo 1 || echo 0)
    if [ ! -d "$WORKTREE_DIR" ]; then
      echo "Error: Worktree directory '$WORKTREE_DIR' does not exist." >&2
      exit 1
    fi

    WORKTREE_ABS="$(cd "$WORKTREE_DIR" && pwd)"
    PARENT_DIR="$(dirname "$WORKTREE_ABS")"
    PRICE_ABS="$PARENT_DIR/price"

    # Cd to price repo first (so git commands work) and to avoid being in a deleted directory
    cd "$PRICE_ABS"

    echo "Removing worktree at '$WORKTREE_ABS'..." >&2
    git worktree remove --force "$WORKTREE_ABS"

    echo "Deleting branch '$BRANCH_NAME'..." >&2
    git branch -D "$BRANCH_NAME"

    echo "Done! Worktree and branch '$BRANCH_NAME' removed." >&2
    [ "$REMOVING_CURRENT" = 1 ] && echo "$PRICE_ABS" > ~/.wt_cd_to
    ;;

  *)
    echo "Error: Unknown command '$COMMAND'"
    echo ""
    show_usage
    ;;
esac
